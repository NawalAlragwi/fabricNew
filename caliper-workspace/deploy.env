# ============================================================================
#  BCMS Caliper Deployment Environment Variables
#  Source this file before running Caliper or deploying chaincode:
#    source caliper-workspace/deploy.env
# ============================================================================

# Allow Go toolchain to download missing modules (BLAKE3 lib) inside containers
export GOFLAGS="-mod=mod"

# Force Go module proxy for reliable dependency resolution
export GOPROXY="https://proxy.golang.org,direct"

# Go sum DB for verification
export GONOSUMDB="*"

# Disable CGO for cross-compilation in Docker containers
export CGO_ENABLED=0

# Fabric version
export FABRIC_VERSION="2.5.0"

# Caliper version
export CALIPER_VERSION="0.6.0"

# Network channel
export CHANNEL_NAME="mychannel"

# Chaincode name (must match benchConfig.yaml contractId)
export CC_NAME="basic"

# Default batch size for S4
export BATCH_SIZE=10

echo "[deploy.env] Environment loaded: GOFLAGS=${GOFLAGS}, CC_NAME=${CC_NAME}"
